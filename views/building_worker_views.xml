<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================= -->
    <!-- VISTAS - Trabajadores de Obra (hr.employee vista simple)      -->
    <!-- FASE 4.5: Jornales — NO pisa vistas nativas del modulo HR     -->
    <!-- ============================================================= -->

    <!-- === FORMULARIO SIMPLE para Control de Obras === -->
    <record id="view_building_employee_form" model="ir.ui.view">
        <field name="name">hr.employee.building.form</field>
        <field name="model">hr.employee</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Trabajador de Obra">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre completo del trabajador"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Datos de Obra">
                            <field name="rol_obra_id"/>
                            <field name="jornal_base"/>
                        </group>
                        <group string="Contacto">
                            <field name="mobile_phone" string="Celular"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- === LISTA SIMPLE para Control de Obras === -->
    <record id="view_building_employee_list" model="ir.ui.view">
        <field name="name">hr.employee.building.list</field>
        <field name="model">hr.employee</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <list string="Trabajadores de Obra">
                <field name="name"/>
                <field name="rol_obra_id"/>
                <field name="jornal_base" string="Jornal Base (MXN/dia)"/>
                <field name="mobile_phone" string="Celular" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- === BUSQUEDA === -->
    <record id="view_building_employee_search" model="ir.ui.view">
        <field name="name">hr.employee.building.search</field>
        <field name="model">hr.employee</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <search string="Buscar Trabajadores">
                <field name="name"/>
                <field name="rol_obra_id"/>
                <separator/>
                <filter string="Con Jornal" name="with_jornal"
                        domain="[('jornal_base', '>', 0)]"/>
                <separator/>
                <filter string="Rol de Obra" name="grp_role"
                        context="{'group_by': 'rol_obra_id'}"/>
            </search>
        </field>
    </record>

    <!-- === ACCION PROPIA con view_ids (NO pisa vistas nativas de HR) === -->
    <record id="action_building_worker" model="ir.actions.act_window">
        <field name="name">Trabajadores de Obra</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_building_employee_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_building_employee_form')})]"/>
        <field name="search_view_id" ref="view_building_employee_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registre a los trabajadores de sus obras.
            </p>
            <p>
                Se usan los empleados nativos de Odoo con campos adicionales
                de jornal base y rol de obra.
            </p>
        </field>
    </record>

</odoo>
