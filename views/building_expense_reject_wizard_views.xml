<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================= -->
    <!-- WIZARD: Rechazo de Gasto (Etapa 5.2)                         -->
    <!-- Aplica tanto a building.real.line como building.work.cost     -->
    <!-- ============================================================= -->
    <record id="view_building_expense_reject_wizard_form" model="ir.ui.view">
        <field name="name">building.expense.reject.wizard.form</field>
        <field name="model">building.expense.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rechazar Gasto">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <strong>Atención:</strong> El gasto será rechazado y el capturista
                        podrá corregirlo y volver a enviarlo.
                    </div>
                    <group>
                        <field name="rejection_reason"
                               placeholder="Describe por qué se rechaza este gasto: partida incorrecta, monto incorrecto, falta documentación, etc."
                               nolabel="1"
                               required="1"/>
                    </group>
                    <field name="record_id" invisible="1"/>
                    <field name="record_model" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirmar Rechazo"
                            type="object" class="btn-danger"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
